# Safe example configuration for public source control.
# Put real deployment values in a local ignored file such as `.env.local`.

SERVERTOOL_NAME=servertool
SERVERTOOL_AUTHOR=zanewang
SERVERTOOL_SHARED_ACCOUNT=clusteruser
SERVERTOOL_WORKSPACE_NAME=YOUR_NAME
SERVERTOOL_SHARED_HOME=/cluster/home/clusteruser
SERVERTOOL_AUTH_URL=https://auth.example.com
SERVERTOOL_NETWORK_PROBE_URL=https://example.com
SERVERTOOL_A40_PARTITION=A40
SERVERTOOL_A6000_PARTITION=A6000
SERVERTOOL_A40_MAX_TIME=15 days
SERVERTOOL_A6000_MAX_TIME=25 days
SERVERTOOL_DEFAULT_COMPUTE_HOST=compute01
SERVERTOOL_QUOTA_LIMIT=300G
SERVERTOOL_CACHE_FILE=$HOME/.cache/servertool/disk-cache.json
SERVERTOOL_TEST_OUTPUT_DIR=/tmp/servertool
SERVERTOOL_INSTALL_PATH=/usr/local/bin/servertool
# SERVERTOOL_CONFIG_FILE=$HOME/.config/servertool/config.env
