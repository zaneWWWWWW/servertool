# Public-safe template for admin-managed lab config.
# Copy to ~/.config/servertool/lab.env and replace placeholders.

export SERVERTOOL_REMOTE_HOST=cluster.example.com
export SERVERTOOL_REMOTE_USER=clusteruser
export SERVERTOOL_REMOTE_PORT=22
export SERVERTOOL_SHARED_ACCOUNT=clusteruser
export SERVERTOOL_SHARED_HOME=/share/home/clusteruser
export SERVERTOOL_REMOTE_ROOT=/share/home/clusteruser/trainhub
export SERVERTOOL_REMOTE_PYTHON=python3

export SERVERTOOL_A40_PARTITION=A40
export SERVERTOOL_A6000_PARTITION=A6000
export SERVERTOOL_A40_MAX_TIME=04:00:00
export SERVERTOOL_A6000_MAX_TIME=08:00:00

export SERVERTOOL_NOTIFY_EMAIL_FROM=notify@example.com
export SERVERTOOL_SMTP_HOST=smtp.example.com
export SERVERTOOL_SMTP_PORT=465
export SERVERTOOL_SMTP_USE_SSL=1

export SERVERTOOL_PIP_INDEX_URL=https://pypi.org/simple
export SERVERTOOL_PIP_EXTRA_INDEX_URL=
export SERVERTOOL_CONDA_CHANNELS=pytorch,nvidia,conda-forge
export SERVERTOOL_HF_ENDPOINT=https://huggingface.co
export SERVERTOOL_MODELSCOPE_ENDPOINT=https://modelscope.cn

export SERVERTOOL_SHARED_ENV_ROOT=/share/home/clusteruser/trainhub/envs
export SERVERTOOL_SHARED_MODEL_ROOT=/share/home/clusteruser/trainhub/models
export SERVERTOOL_SHARED_CACHE_ROOT=/share/home/clusteruser/trainhub/cache
