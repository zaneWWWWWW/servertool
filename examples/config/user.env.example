# Public-safe template for member-managed personal config.
# Copy to ~/.config/servertool/user.env and replace placeholders.

export SERVERTOOL_WORKSPACE_NAME=YOUR_NAME
export SERVERTOOL_MEMBER_ID=YOUR_NAME
export SERVERTOOL_NOTIFY_EMAIL_TO=you@example.com
export SERVERTOOL_LOCAL_RUN_CACHE=$HOME/.cache/servertool/runs
