{
  "version": "2",
  "project": "servertool",
  "run_name": "smoke-train",
  "assets": {
    "code": {
      "source": "sync",
      "path": "."
    },
    "dataset": {
      "source": "none"
    },
    "env": {
      "source": "none"
    },
    "model": {
      "source": "none"
    }
  },
  "launch": {
    "scheduler": "slurm",
    "partition": "A40",
    "gpus": 1,
    "cpus": 1,
    "mem": "4G",
    "time": "00:10:00",
    "workdir": ".",
    "command": "python examples/smoke_train.py --steps 3 --output-dir outputs --ckpt-dir ckpts"
  },
  "fetch": {
    "include": [
      "outputs/**",
      "ckpts/**"
    ]
  },
  "notify": {
    "email": {
      "enabled": false,
      "to": []
    }
  }
}
